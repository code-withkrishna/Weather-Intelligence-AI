# Copy this file to .env for Docker Compose.
# For local dev, copy it to backend/.env and create frontend/.env.local with
# only NEXT_PUBLIC_API_BASE_URL.

# --- App ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
DATABASE_URL=sqlite:///./weather.db

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Weather provider (required for live data; app runs without it too) ---
WEATHER_PROVIDER=openweathermap
OPENWEATHER_API_KEY=
WEATHERAPI_KEY=

# --- Optional extra integrations ---
YOUTUBE_API_KEY=

# --- AI assistant (works with zero config via the rule-based engine) ---
AI_PROVIDER=rule_based
GROQ_API_KEY=
OPENAI_API_KEY=
